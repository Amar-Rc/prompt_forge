# Copy this file to .env and fill in your keys.
# Only set the keys for providers you actually use.

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (GPT-4o, etc.)
OPENAI_API_KEY=sk-...

# Google Gemini
GEMINI_API_KEY=AIza...

# Groq (fast Llama inference)
GROQ_API_KEY=gsk_...

# Ollama and MLX are local — no key needed.
